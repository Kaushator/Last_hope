{
  "model": "gpt-4o-mini",
  "temperature": 0.1,
  "max_tokens": 600,
  "stream": true,
  "context_window_limit": 4096,
  "stop_on_files_over_kb": 256,
  "prefer_diff_patches": true,
  "reuse_context_from": ["./apps/backend", "./apps/frontend"],
  "compression": { "strip_comments": true, "strip_binaries": true },
  "telemetry": false,
  "prompt_policy": {
    "style": "concise",
    "avoid_repetition": true,
    "no-regenerate-on-warn": true
  }
}
