# Общие
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=LastHope

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/last_hope
REDIS_URL=redis://cache:6379/0

# Ключи (заполни вручную)
HTX_API_KEY=
HTX_API_SECRET=
COINGECKO_API_KEY=
OPENAI_API_KEY=

# Сервис FinGPT
FINGPT_URL=http://fingpt:9000

# Файлы
CSV_MAX_MB=10
UPLOAD_DIR=/data/uploads
