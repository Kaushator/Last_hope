# Общие
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=LastHope

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/last_hope
REDIS_URL=redis://cache:6379/0

# Ключи (заполни вручную)
HTX_API_KEY=
HTX_API_SECRET=
COINGECKO_API_KEY=
OPENAI_API_KEY=

# Сервис FinGPT
FINGPT_URL=http://fingpt:9000

# Файлы
CSV_MAX_MB=10
UPLOAD_DIR=/data/uploads

# Feature Flags
ENABLE_HTX_API=true
ENABLE_FINGPT=false
ENABLE_GCS=false

# GCS Configuration (optional)
GCS_BUCKET_NAME=last-hope-analytics
GCS_KEY_FILE=
USE_MINIO=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
LOCAL_STORAGE_PATH=./data/reports
