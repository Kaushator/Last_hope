# Last Hope — example environment

# Server
PORT=4000

# GitHub
GITHUB_TOKEN=

# Fernet (choose ONE strategy)
# 1) Use a master key in env for Node decryptor (when implemented)
FERNET_MASTER_KEY=
# 2) Or use Python tool-backed files (secret.key + api.enc) managed outside env

# HTX (do NOT store plaintext keys in Git!)
# Provide encrypted forms via Fernet, or set via environment only in local dev/CI.
ENCRYPTED_HTX_API_KEY_PATH=./secrets/htx_api_key.enc
ENCRYPTED_HTX_API_SECRET_PATH=./secrets/htx_api_secret.enc

# GCP (Phase 2)
GCP_PROJECT=
GCS_BUCKET=
GCP_SA_KEY=
ENABLE_FINGPT=false
FINGPT_URL=

